SUPABASE_URL
SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY
OPENAI_API_KEY
CANVA_CLIENT_ID
CANVA_CLIENT_SECRET

# Optional Marathi editor-polish via Sarvam-30B (off by default). Improves flow/tone only,
# never facts; the existing faithfulness check runs after it. Requires SARVAM_API_KEY when on.
# Sarvam models are hybrid-reasoning; reasoning is disabled by default here (it only burns
# the token budget on a copy-edit task). Both knobs below are optional — defaults shown.
# ENABLE_SARVAM_POLISH=true
# SARVAM_API_KEY=sk_xxx
# SARVAM_MODEL=sarvam-30b
# SARVAM_BASE_URL=https://api.sarvam.ai/v1/chat/completions
# SARVAM_MAX_TOKENS=4096            # budget covers reasoning + reply; Sarvam's default 2048 is too low.
#                                  # NOTE: the starter tier caps sarvam-30b max_tokens at 4096 — do not
#                                  # raise this above your plan's limit or requests 400.
# SARVAM_REASONING_EFFORT=none      # none|low|medium|high — 'none' disables thinking (default)

# apps/api (all optional — defaults shown)
# HOST=127.0.0.1
# PORT=3001
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Poster background image (all optional). The image model now paints ONLY a text-free
# photo; the poster's Marathi text/header/footer are typeset in HTML and screenshotted
# with Chromium, so Devanagari is always crisp regardless of the image model.
# OPENAI_IMAGE_MODEL defaults to gpt-image-1.
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1536x1024   # landscape scene, cover-cropped into the photo zone
# OPENAI_IMAGE_QUALITY=high

# n8n social-post workflow (webhook trigger of social-post-v2-api). Required for the
# 'twitter' generation category — the API's background job POSTs meeting notes here and
# awaits { post_type, title, caption, poster_png_base64 }.
N8N_SOCIAL_POST_WEBHOOK_URL=http://localhost:5678/webhook/dgipr-social-post
# Base URL of THIS api, reachable from n8n. Used to build the progress_url that n8n
# pings after each stage (local: http://localhost:3001; on AWS the internal URL).
API_PUBLIC_URL=http://localhost:3001
# N8N_WEBHOOK_SECRET=                          # optional shared-secret header (recommended on AWS)

