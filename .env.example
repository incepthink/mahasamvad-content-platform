SUPABASE_URL
SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY
OPENAI_API_KEY
CANVA_CLIENT_ID
CANVA_CLIENT_SECRET

# apps/api (all optional — defaults shown)
# HOST=127.0.0.1
# PORT=3001
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Poster background image (all optional). The image model now paints ONLY a text-free
# photo; the poster's Marathi text/header/footer are typeset in HTML and screenshotted
# with Chromium, so Devanagari is always crisp regardless of the image model.
# OPENAI_IMAGE_MODEL defaults to gpt-image-1.
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1536x1024   # landscape scene, cover-cropped into the photo zone
# OPENAI_IMAGE_QUALITY=high

