SUPABASE_URL
SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY
OPENAI_API_KEY
CANVA_CLIENT_ID
CANVA_CLIENT_SECRET

# OpenAI transport (all optional — defaults shown). Every chat/embedding call is serialized
# process-wide and retried on transient failures (429 / 408 / 409 / 5xx / network), preferring
# the wait OpenAI names in its retry-after / x-ratelimit-reset-* headers.
# One scheme article is 8-15 gpt-4o calls carrying the full note and article (~5-8k tokens
# each), so at OpenAI usage tier 1 (30,000 TPM on gpt-4o) concurrency MUST stay at 1 — two
# in-flight requests will trip the token bucket. Raise it to 2-4 only on tier 2+ (450k TPM),
# where it restores real parallelism to the coverage checks and cuts wall-clock noticeably.
# OPENAI_MAX_CONCURRENCY=1
# OPENAI_MAX_RETRIES=5              # retries AFTER the first attempt
# OPENAI_REQUEST_TIMEOUT_MS=180000  # per-request; a hung call would otherwise block the queue

# Optional Marathi editor-polish via Sarvam-30B (off by default). Improves flow/tone only,
# never facts; the existing faithfulness check runs after it. Requires SARVAM_API_KEY when on.
# Sarvam models are hybrid-reasoning; reasoning is disabled by default here (it only burns
# the token budget on a copy-edit task). Both knobs below are optional — defaults shown.
# ENABLE_SARVAM_POLISH=true
# SARVAM_API_KEY=sk_xxx
# SARVAM_MODEL=sarvam-30b
# SARVAM_BASE_URL=https://api.sarvam.ai/v1/chat/completions
# SARVAM_MAX_TOKENS=4096            # budget covers reasoning + reply; Sarvam's default 2048 is too low.
#                                  # NOTE: the starter tier caps sarvam-30b max_tokens at 4096 — do not
#                                  # raise this above your plan's limit or requests 400.
# SARVAM_REASONING_EFFORT=none      # none|low|medium|high — 'none' disables thinking (default)

# apps/api (all optional — defaults shown)
# HOST=127.0.0.1
# PORT=3001
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Poster background image (all optional). The image model now paints ONLY a text-free
# photo; the poster's Marathi text/header/footer are typeset in HTML and screenshotted
# with Chromium, so Devanagari is always crisp regardless of the image model.
# OPENAI_IMAGE_MODEL defaults to gpt-image-1.
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1536x1024   # landscape scene, cover-cropped into the photo zone
# OPENAI_IMAGE_QUALITY=high

# n8n social-post workflow (webhook trigger of social-post-v2-api). Required for the
# 'twitter' generation category — the API's background job POSTs meeting notes here and
# awaits { post_type, title, caption, poster_png_base64 }. The workflow is host-independent:
# it fetches its brand templates over HTTPS from Supabase (posters/references/*), so the
# same exported JSON (n8n/workflow-exports/social-post-v2-api.json) runs locally and on AWS.
#   LOCAL:  http://localhost:5678/webhook/dgipr-social-post
#   AWS:    the deployed n8n webhook URL — a private VPC address if the API and n8n share a
#           network, otherwise the public HTTPS URL of the n8n instance.
N8N_SOCIAL_POST_WEBHOOK_URL=http://localhost:5678/webhook/dgipr-social-post
# n8n webhook for the ARTICLE poster (news/scheme, outputType poster/both). Like the
# social-post workflow, the API sends only { headline, scene_brief, generation_id } and
# n8n *only renders*: it edits the master-article template (posters/references/master-
# article.png, fetched over HTTPS) with gpt-image-2 and returns { poster_png_base64 }.
# The exported JSON is n8n/workflow-exports/article-poster-v1-api.json.
#   LOCAL:  http://localhost:5678/webhook/dgipr-article-poster
#   AWS:    the deployed n8n webhook URL (private VPC address if shared network, else public HTTPS).
N8N_ARTICLE_POSTER_WEBHOOK_URL=http://localhost:5678/webhook/dgipr-article-poster
# Article poster renderer: 'n8n' (default) renders via the workflow above; 'html' uses the
# original local AI-photo + HTML/Playwright render (packages/poster-renderer). Only the
# 'html' path produces a separate scene image, so poster feedback / manual copy-edit
# (which need a scenePath) work only in 'html' mode.
# ARTICLE_POSTER_MODE=n8n
# Base URL of THIS api, reachable from n8n. Used to build the progress_url that n8n
# pings after each stage (local: http://localhost:3001; on AWS the API's internal URL).
API_PUBLIC_URL=http://localhost:3001
# Shared secret between the API and n8n. When set, the API sends it as the
# x-n8n-webhook-secret header on the webhook call. To ENFORCE it on the n8n side (AWS),
# set the workflow's Webhook node Authentication to "Header Auth" and create a Header Auth
# credential with Name = x-n8n-webhook-secret and Value = this secret — n8n then rejects
# mismatches with 403 before the workflow runs. (This keeps the secret in an n8n credential,
# not in the committed workflow JSON, and needs no in-node env access.) Leave unset locally:
# with Header Auth off, the webhook is open, which is fine behind localhost.
# N8N_WEBHOOK_SECRET=

# Shipping workflow changes to a running n8n (`pnpm n8n:push`). n8n stores workflows in its
# own database, NOT on disk — a `git pull` on the n8n host changes nothing. `pnpm n8n:push`
# pushes n8n/workflow-exports/*.json into the instance below over its public REST API,
# matching by workflow name and preserving that instance's credential ids + webhook Header
# Auth. Point it at whichever n8n you mean to update (prod is the usual case):
#   N8N_API_URL=https://n8n.indicex.xyz   # or http://localhost:5678 for the local dev n8n
# The key is created in the n8n editor: Settings -> n8n API -> Create an API key.
# N8N_API_URL=https://n8n.indicex.xyz
# N8N_API_KEY=

