{
  "name": "@dgipr/content-engine",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier src --write",
    "format:check": "prettier src --check",
    "scrape:karjamukti": "tsx src/scraping/mahasamvad-rest.ts",
    "chunk:karjamukti": "tsx src/chunking/chunk-articles.ts",
    "embed:karjamukti": "tsx --env-file=../../.env src/embedding/ingest-chunks.ts",
    "scrape:news": "tsx src/scraping/mahasamvad-rest.ts 16 mahasamvad-news 250",
    "chunk:news": "tsx src/chunking/chunk-articles.ts mahasamvad-news news",
    "embed:news": "tsx --env-file=../../.env src/embedding/ingest-chunks.ts mahasamvad-news",
    "retrieve:test": "tsx --env-file=../../.env src/retrieval/retrieve-references.ts",
    "generate:test": "tsx --env-file=../../.env src/generation/generate-article.ts",
    "polish:test": "tsx --env-file=../../.env src/generation/polish-article.ts"
  },
  "dependencies": {
    "@dgipr/database": "workspace:*",
    "@dgipr/poster-renderer": "workspace:*",
    "@dgipr/schemas": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^29.1.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "tsx": "^4.19.2"
  }
}
