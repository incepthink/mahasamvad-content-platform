{
  "name": "@dgipr/poster-renderer",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@dgipr/schemas": "workspace:*",
    "ffmpeg-static": "^5.2.0",
    "playwright": "^1.49.1",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier src --write",
    "format:check": "prettier src --check",
    "assets:extract": "tsx scripts/extract-brand-assets.ts",
    "assets:cmo-frame": "tsx scripts/build-cmo-photo-frame.ts",
    "poster:preview": "tsx scripts/preview.ts",
    "poster:preview:article": "tsx scripts/preview-article.ts",
    "poster:preview:chrome": "tsx scripts/preview-article-chrome.ts",
    "poster:preview:chrome:twitter": "tsx scripts/preview-twitter-chrome.ts",
    "poster:preview:chrome:cmo": "tsx scripts/preview-cmo-chrome.ts",
    "poster:preview:markers": "tsx scripts/preview-feedback-marker.ts",
    "video:preview:assemble": "tsx scripts/preview-video-assembly.ts",
    "video:preview:narrate": "tsx scripts/preview-video-narrate.ts",
    "docs:shots": "tsx scripts/docs-shots/cli.ts"
  }
}
