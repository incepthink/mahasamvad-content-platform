# Keep the Docker build context small and never ship secrets or local build
# artifacts into the image (they get rebuilt inside the container anyway).
node_modules
**/node_modules
**/dist
**/.next
**/.turbo
**/*.tsbuildinfo
coverage

# Secrets / local env — env is injected at runtime by docker-compose, never baked in.
.env
.env.local
.env.*.local
deploy/.env.prod

# Scraped content output (gitignored, regenerated by the content pipeline)
packages/content-engine/data/

# VCS / editor / OS noise
.git
.gitignore
**/*.log
.DS_Store
