# Copy to deploy/.env.prod on the EC2 host and fill in. This is the API
# container's runtime env. NEVER commit the filled-in file (deploy/.env.prod is
# gitignored + dockerignored).
#
# Note: N8N_SOCIAL_POST_WEBHOOK_URL, N8N_ARTICLE_POSTER_WEBHOOK_URL and API_PUBLIC_URL
# are intentionally NOT set here — docker-compose.yml sets them to the internal service
# URLs (http://n8n:5678 / http://api:3001), which override anything in this file.
# ARTICLE_POSTER_MODE also defaults to 'n8n' in compose; set it to 'html' there to use
# the in-container HTML/Playwright renderer instead.

# --- Supabase (your existing project — same as local) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI (article generation + poster background image) ---
OPENAI_API_KEY=sk-...
# Optional image knobs (defaults are fine):
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1536x1024
# OPENAI_IMAGE_QUALITY=high

# --- CORS: MUST list your Vercel origin(s) so the browser can call the API ---
# Comma-separated, no trailing slash. Add your custom domain too if you set one.
CORS_ORIGIN=https://YOUR-APP.vercel.app

# --- n8n shared secret ---
# The API sends this as the x-n8n-webhook-secret header. To ENFORCE it, set the
# workflow's Webhook node Authentication = "Header Auth" with a Header Auth
# credential named x-n8n-webhook-secret = this value.
N8N_WEBHOOK_SECRET=generate-a-long-random-string

# --- Optional: Marathi editor-polish via Sarvam (off by default) ---
# ENABLE_SARVAM_POLISH=true
# SARVAM_API_KEY=sk_xxx
# SARVAM_MODEL=sarvam-30b
# SARVAM_MAX_TOKENS=4096
